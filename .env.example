# =============================================================
# COC Upgrade Notifier - 环境变量配置
# =============================================================
# 复制此文件为 .env 并填入你的实际值: cp .env.example .env
# =============================================================

# --- Clash of Clans API ---
# 从 https://developer.clashofclans.com 获取 API Key
# 注意:
#   - 本地运行: API Key 需要绑定你的公网 IP
#   - GitHub Actions: API Key 需要绑定 GitHub Actions 的出口 IP
#     （可在 Actions 运行日志中看到 IP，然后去 COC 开发者后台更新）
COC_API_KEY=你的COC_API_KEY

# 要监控的玩家标签（游戏内复制，格式: #XXXXXXXX）
# 支持多个玩家，用英文逗号分隔
COC_PLAYER_TAGS=#YOUR_PLAYER_TAG

# --- WxPusher 推送 ---
# 从 https://wxpusher.zjiecode.com/admin/ 创建应用后获取
WXPUSHER_APP_TOKEN=你的APP_TOKEN

# 接收推送的用户 UID
# 关注公众号「wxpusher」→「我的」→「我的UID」获取
# 支持多个 UID，用英文逗号分隔
WXPUSHER_UIDS=UID_xxxxxxxx

# --- 轮询设置（仅本地常驻模式生效）---
# 轮询间隔（分钟），建议 10-30 分钟
# 过于频繁可能触发 API 限流
# GitHub Actions 模式下，轮询间隔由工作流 cron 决定
POLL_INTERVAL_MINUTES=15

# --- 可选: 主题推送（群发）---
# 如果设置了主题ID，消息会同时推送给主题下所有用户
# WXPUSHER_TOPIC_IDS=123,456

# --- GitHub Actions 专用: Gist 快照持久化 ---
# 在 GitHub Actions 中运行时，每次都是全新环境，本地文件不会保留
# 需要用 GitHub Gist 来保存/读取上次的快照数据
# 如果不配置 Gist，则每次运行都不知道上次的状态，无法检测升级变化

# GitHub Personal Access Token（需要 gist 权限）
# 生成方式: GitHub → Settings → Developer settings → Personal access tokens → Generate new token
# 勾选 gist 权限
GIST_TOKEN=

# Gist ID（创建一个 Gist 后获取）
# 创建方式: 访问 https://gist.github.com → New Gist → 随便写个内容 → Create
# 从 URL 中复制 ID，例如 https://gist.github.com/yourname/abc123 → ID 就是 abc123
GIST_ID=
